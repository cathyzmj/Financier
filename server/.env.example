# Financier backend — environment variables
# Copy this file to ".env" and fill in real values. The real .env is gitignored.

# Anthropic API key — used by the upcoming AI memo-critique / chat features.
# Get one at https://console.anthropic.com/. Leave blank until those features are added.
ANTHROPIC_API_KEY=

# Optional: override the default model (defaults to a Haiku model in code).
# ANTHROPIC_MODEL=claude-haiku-4-5
